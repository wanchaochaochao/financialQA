# Financial QA System - Environment Variables Template
# ====================================================
# Copy this file to .env and fill in your actual values

# ==================== API Server Configuration ====================

# Backend (Python FastAPI)
# -----------------------
# API Server Host (default: 0.0.0.0 - listens on all interfaces)
# 0.0.0.0 - 监听所有网络接口（适合云服务器）
# 127.0.0.1 - 仅本地访问
API_HOST=0.0.0.0

# API Server Port (default: 8000)
# 本地开发环境使用 8000，云服务器可以修改为其他端口
API_PORT=8000

# API Base URL (用于生成图表的可访问 HTTP URL)
# 本地开发环境
API_BASE_URL=http://localhost:8000
# 云服务器部署示例（修改为你的实际地址）
# API_BASE_URL=http://your-server-ip:8000
# API_BASE_URL=https://api.yourdomain.com

# Frontend (Next.js)
# -----------------------
# Frontend Port (default: 3000)
# 本地开发环境使用 3000，云服务器可以修改为其他端口
# 注意：Next.js 使用环境变量 PORT（不是 FRONTEND_PORT）
# 此变量在启动脚本中会被传递给 Next.js
PORT=3000

# ==================== OpenAI API Configuration ====================
# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom OpenAI API endpoint (e.g., for proxy or compatible services)
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== LLM Model Configuration ====================
# Language model to use
LLM_MODEL=gpt-4.1-mini

# Temperature for LLM (0 = deterministic, 1 = creative)
LLM_TEMPERATURE=0

# Embedding model for RAG
EMBEDDING_MODEL=text-embedding-ada-002

# ==================== RAG Configuration ====================
# Document chunk size (characters)
CHUNK_SIZE=500

# Chunk overlap size (characters)
CHUNK_OVERLAP=100

# Number of documents to retrieve
RETRIEVAL_TOP_K=3

# ==================== Agent Configuration ====================
# Maximum iterations for agent
AGENT_MAX_ITERATIONS=15

# Maximum execution time (seconds)
AGENT_MAX_EXECUTION_TIME=60

# Enable verbose output for debugging
AGENT_VERBOSE=true

# ==================== Optional: Alternative Data Sources ====================
# Alpha Vantage API key (optional, for alternative financial data)
# Get your free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=PXO6QTORHXE65SVQ

# ==================== Optional: Web Search ====================
# Enable web search for news and market analysis
USE_WEB_SEARCH=false

# ==================== Optional: AI Image Generation ====================
# Tu-zi.com AI Image Generation API Key (用于生成流程图、架构图等)
# 获取 API Key: https://tu-zi.com
# TUZI_API_KEY=your-tuzi-api-key-here
